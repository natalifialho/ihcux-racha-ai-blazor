@using RachaAiBlazor.Models

<div class="card shadow-sm mb-3" style="border-left: 5px solid @(Grupo.NoVermelho ? "#dc3545" : "#198754")">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-0"><strong>@Grupo.Nome</strong></h5>
            <span class="badge bg-secondary">@Grupo.Categoria</span>
        </div>
        <div class="text-end">
            <p class="mb-0 @(Grupo.NoVermelho ? "text-danger" : "text-success") fw-bold">
                @(Grupo.NoVermelho ? "-" : "+") @Grupo.ValorPendente.ToString("C2")
            </p>
        </div>
    </div>
</div>

@code {
    [Parameter] public Grupo Grupo { get; set; } = new();
}